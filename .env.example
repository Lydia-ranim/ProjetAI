APP_NAME=LYHLYH Transit API
APP_VERSION=1.1.0
DATA_DIR=./data

# Browser-restricted Google Maps key.
# Enable: Maps JavaScript API, Places API, Geocoding API.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_REGION=DZ
GOOGLE_MAPS_LANGUAGE=fr

CORS_ORIGINS=*
POLYLINE_SIMPLIFY_TOLERANCE=0.00008
MAX_POLYLINE_POINTS=600
NEAREST_STOP_CACHE_SIZE=512
GOOGLE_VISUAL_DIRECTIONS=true
